{
  "desc": "List app collaborators",
  "http_method": "POST",
  "scope": {
    "bot": [
      "apps"
    ],
    "user": [
      "apps"
    ]
  },
  "rate_limits": "t2",
  "args": {
    "type": "object",
    "required": [
      "token",
      "app_id"
    ],
    "properties": {
      "token": {
        "type": "string",
        "subtype": "auth",
        "example": "xxxx-xxxxxxxxx-xxxx"
      },
      "app_id": {
        "type": "string",
        "desc": "The ID of the app to attach the collaborator to."
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "ok": {
        "type": "boolean"
      },
      "owner_ids": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "owners": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "username": {
              "type": "string"
            },
            "user_email": {
              "type": "string"
            },
            "user_id": {
              "type": "string"
            },
            "permission_type": {
              "type": "string",
              "desc": "Defines what level of access this collaborator has to the app.",
              "enum": [
                "owner",
                "reader"
              ]
            }
          }
        }
      }
    }
  },
  "errors": {
    "app_not_owned_by_manager_app": {
      "desc": "The specified app is not managed by the calling manager app."
    },
    "cannot_list_collaborators": {
      "desc": "Calling user is unable to list collaborators."
    },
    "cannot_list_owners": {
      "desc": "Calling user is unable to list collaborators."
    },
    "app_not_found": {
      "desc": "The given app cannot be found."
    },
    "enterprise_is_restricted": {
      "desc": "Org-level tokens are not allowed."
    },
    "user_not_found": {
      "desc": "The given user cannot be found."
    }
  }
}